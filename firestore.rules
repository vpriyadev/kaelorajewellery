rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Products Rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles Rules
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read, write: if isAdmin();
      
      // Nested user addresses rules
      match /addresses/{addressId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        allow read, write: if isAdmin();
      }
    }

    // Orders Rules
    match /orders/{orderId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAdmin();
    }

    // Reviews Rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Store Settings Rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Email Logs Rules
    match /emailLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
